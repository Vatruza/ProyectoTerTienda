{
  "name": "makeup-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "mobile:build": "npm run build && npx cap sync android",
    "mobile:sync": "npx cap sync android",
    "mobile:open:android": "npx cap open android",
    "mobile:run:android": "npx cap run android",
    "lint": "eslint .",
    "security:audit:prod": "npm audit --omit=dev",
    "security:audit:dev": "npm audit",
    "security:scan": "powershell -ExecutionPolicy Bypass -File ../security-scan.ps1",
    "security:scan:local": "npm run security:audit:prod",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:slow": "set PWTEST_SLOW_MO=700&& playwright test --headed",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.7"
  }
}
